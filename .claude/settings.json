{
  "permissions": {
    "allow": [
      "mcp__aiperture__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf --retry 3 --retry-delay 1 --retry-connrefused http://localhost:8100/hooks/session-start 2>/dev/null || echo '{}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "^(?!mcp__aiperture__).*",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:8100/hooks/permission-request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?!mcp__aiperture__).*",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:8100/hooks/post-tool-use"
          }
        ]
      }
    ]
  }
}
